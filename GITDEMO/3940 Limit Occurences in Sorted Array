class Solution {
public:
    vector<int> limitOccurrences(vector<int>& nums, int k) {
        vector<int> arr;
        int n = nums.size();
        if(n <= k)
            return nums;

        int j = k;
        
        for(int i = k; i < n; i++) {
            if(nums[i] != nums[j-k]) {
                nums[j] = nums[i];
                j++;
            }
        }
        nums.resize(j);
        return nums;
    }
};