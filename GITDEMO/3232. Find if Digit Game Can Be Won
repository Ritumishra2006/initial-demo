class Solution {
public:
    bool canAliceWin(vector<int>& nums) {
        int sum = 0;
        int DSum = 0;
        int n = nums.size();
       for(int i = 0; i < n; i++) {
          if(nums[i] >= 1 && nums[i] <= 9) {
            sum += nums[i];
          } 
          else {
            DSum += nums[i];
          }
       }
     return (sum != DSum) ? true : false;
    }
};