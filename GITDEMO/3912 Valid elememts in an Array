class Solution {
public:
    vector<int> findValidElements(vector<int>& nums) {
        int n = nums.size();
        if(n==0) {
            return {};
        }

    vector<bool> isValid(n, false);
        
         int left = INT_MIN;
        for(int i = 0; i < n; i++) {
            if (nums[i] > left) {
                isValid[i] = true;
                left = nums[i];
            }
        }
        int right = INT_MIN;
        for(int i = n-1 ; i >= 0; i--) {
            if(nums[i] > right) {
                isValid[i] = true;
                right = nums[i];
            }
        } 
        vector<int> result;
        for(int i = 0; i < n; i++) {
            if(isValid[i]) {
                result.push_back(nums[i]);
            }
        }
        return result;
        
    }
};