class Solution {
public:
    int maxNumberOfBalloons(string text) {
        int b = 0, a = 0, l = 0, o = 0, n = 0;
        for(int i : text) {
            if(i == 'b') b++;
            else if (i == 'a') a++;
             else if (i == 'l') l++;
              else if (i == 'o') o++;
              else if (i == 'n') n++;
        }
         return min({b,a,l/2,o/2,n});
    }
};