
#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    // code here
    int st = 1;
    for(int i = 1; i<=n; i++) {
        for(int j = 1; j <= st; j++){
            cout << "* ";
        }
        cout << endl;
        st++;
    }
    
    st = n-1;
    for(int i = 1; i<=n-1; i++) {
        for(int j = 1; j <= st; j++){
            cout << "* ";
        }
        cout << endl;
        st--;
    }

    return 0;
}