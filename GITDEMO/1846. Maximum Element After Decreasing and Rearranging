class Solution {
public:
    int maximumElementAfterDecrementingAndRearranging(vector<int>& arr) {
        int n = arr.size();
        int ans = 1;
        sort(arr.begin(),arr.end());
        for(int i = 1; i < n; i++) {
           if(arr[i] >= ans+1) {
            ans++;
           }
        }
        return ans;
    }
};