class Solution {
public:
    bool isGood(vector<int>& nums) {
        int n = nums.size() - 1;
        bool dup = 0;

        for (auto& num : nums) {
            int value = abs(num);
            if (value > n) return false;

            if (nums[value - 1] < 0) {
                if (value < n || dup) return false;
                dup |= 1;
                continue;
            }

            nums[value - 1] = -nums[value - 1];
        }

        return true;
    }
};