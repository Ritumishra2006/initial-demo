class Solution {
public:
    vector<string> generateValidStrings(int n, int k) {
        pair<int, int> L = {n, k};
        vector<string> result;

        int total_com = 1 << n;

        for (int i = 0; i < total_com; i++) {
            string s = "";
            int cost = 0;
            bool valid = true;

            for (int j = n - 1; j >= 0; j--) {
                if ((i >> j) & 1) {
                    s += '1';
                    int idx = n - 1 - j;
                    cost += idx;
                } else {
                    s += '0';
                }
            }

            for (int j = 0; j < n - 1; j++) {
                if (s[j] == '1' && s[j + 1] == '1') {
                    valid = false;
                    break;
                }
            }

            if (cost > k) {
                valid = false;
            }

            if (valid) {
                result.push_back(s);
            }
        }
        return result;
    }
};