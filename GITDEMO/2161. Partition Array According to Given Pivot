class Solution {
public:
    vector<int> pivotArray(vector<int>& nums, int pivot) {
        int n = nums.size();
        vector<int> result(n);
        int left = 0;
        int right = n-1;
        int j ;
        for(int i = 0, j = n-1; i < n; i++, j--) {
            if(nums[i] < pivot ) {
               result[left++] = nums[i];
            }
            if(nums[j] > pivot) {
                result[right--] = nums[j];
            }
        }
        while(left <= right) {
            result[left++] = pivot;
        }
        return result;
    }
};