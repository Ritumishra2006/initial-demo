class Solution {
public:
    bool searchMatrix(vector<vector<int>>& mat, int tar) {
        int m = mat.size(), n = mat[0].size();
        int r = 0, c = n-1;
        

        //choose the mid 15 or 18, we have choosen 18 here
        
        while(c >= 0 && r < m) {
            if(tar == mat[r][c]) {
                return true;
            }
            else if(tar < mat[r][c]) {
                c--;
            }
            else if(tar > mat[r][c]) {
                r++;
            }
        }
        return false;
    }
};