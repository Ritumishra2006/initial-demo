class Solution {
public:
    void reverseArr(vector<int>& arr, int i, int j) {
             while(i < j) {
                swap(arr[i], arr[j]);
                i++;
                j--;
             }
    } 
    void rotate(vector<int>& arr, int k) {
        int n = arr.size();
        k%=n;
       reverseArr(arr, 0, k-1);
       reverseArr(arr, k, n-1);
       reverseArr(arr, 0, n-1);
    }
};