class Solution {
public:
    int smallestIndex(vector<int>& nums) {
        int mini = 1e9;
        int n = nums.size();
        for(int i = 0; i < n; i++) {
             int sum = 0;
            int num = nums[i];
            while(num > 0) {
                int dig = 0;
                dig = num%10;
                sum += dig;
                num /= 10;
            }
                if(i == sum) {
                    mini = min(i,mini);
                    return mini;
                   
                }
            }
            
        
        return -1;
    }
};